{
  "name": "codex-gtd",
  "version": "0.5.0",
  "description": "Aegis Codex Orchestrator: a minimal Codex SDK orchestration loop using a file-based agent protocol.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/rony99/aegis-codex-orchestrator#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rony99/aegis-codex-orchestrator.git"
  },
  "bugs": {
    "url": "https://github.com/rony99/aegis-codex-orchestrator/issues"
  },
  "keywords": [
    "codex",
    "agent",
    "orchestration",
    "ai-coding",
    "developer-tools"
  ],
  "files": [
    "dist/",
    "src/",
    "docs/",
    "examples/",
    "web/",
    "snippets/*.md",
    "test/",
    "README.md",
    "LICENSE",
    "package.json",
    "tsconfig.json"
  ],
  "bin": {
    "codex-gtd": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:core": "npm run build && node --test test/cli.test.mjs",
    "test:server": "npm run build && node --test test/server.test.mjs",
    "test:local": "npm run build && node --test test/cli.test.mjs && node --test test/server.test.mjs",
    "dev": "tsx src/cli.ts",
    "smoke": "tsx src/cli.ts smoke --model gpt-5.4",
    "smoke:cli-local": "npm run build && node dist/cli.js doctor && node dist/cli.js sdk-probe --model gpt-5.4 --raw-cli --json",
    "server": "node dist/server/index.js",
    "dev-server": "tsx src/server/index.ts"
  },
  "dependencies": {
    "@openai/codex-sdk": "0.123.0",
    "express": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}
